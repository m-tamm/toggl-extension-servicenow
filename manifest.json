{
  "manifest_version": 3,
  "name": "Toggl Day Import Helper",
  "description": "Fetch Toggl entries for a day and import a selected entry date into the current page. (Built for ServiceNow)",
  "version": "0.9.0",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://api.track.toggl.com/*"],
  "action": {
    "default_title": "Toggl Import",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
